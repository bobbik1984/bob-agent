# 1. OpenClaw Node Gateway (WebSocket 核心节点接入)

http://openclaw.bobbik.org {

    reverse_proxy 127.0.0.1:18789 {

        header_up Host {host}

        header_up X-Forwarded-Proto https

    }

}



# 2. Headscale UI & API (网络控制??

http://hs.bobbik.org, http://115.190.248.194 {

    # Headscale 后端 API 接口 (宿主??41641 端口)

    handle /api/* {

        reverse_proxy 127.0.0.1:41641

    }

    handle /machine/* {

        reverse_proxy 127.0.0.1:41641

    }

    # 其它 headscale 必要的路??
    handle /ts2021* { 

        reverse_proxy 127.0.0.1:41641 

    }

    handle /register/* { 

        reverse_proxy 127.0.0.1:41641 

    }

    

    # 静??Web UI 页面 (转发回阉割后??headscale-ui 容器新开??8001 端口)

    handle {

        reverse_proxy 127.0.0.1:8001

    }

}



