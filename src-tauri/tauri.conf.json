{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "bob",
  "version": "0.3.1-0",
  "identifier": "com.bob.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bob",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../resources/llm-engine/*.exe": "llm-engine",
      "../resources/llm-engine/*.dll": "llm-engine",
      "../resources/llm-engine/*.disabled": "llm-engine",
      "pdfium.dll": "pdfium.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
