{
  "name": "bob-agent",
  "version": "0.1.0",
  "description": "AI 桌面私人秘书 — 智能对话 + 图片识别 + 日程管理 + 文件分析",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/wait-for-vite.js && electron .",
    "build": "vite build",
    "pack": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ electron/"
  },
  "build": {
    "appId": "com.bob.agent",
    "productName": "bob-agent",
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "highlight.js": "^11.10.0",
    "lucide-vue-next": "^1.0.0",
    "mammoth": "^1.8.0",
    "marked": "^14.0.0",
    "marked-highlight": "^2.2.0",
    "openai": "^4.80.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0"
  }
}
