{
  "_readme": "Your personal CSS token baseline. Edit these to reflect your preferred defaults. The skill will reference this file when suggesting token merges for analyzed sites.",

  "colors": {
    "bg": "#000000",
    "bg_secondary": "#111111",
    "primary": "#3fb950",
    "primary_hover": "#2ea043",
    "text": "#e6e6e6",
    "text_muted": "#888888",
    "border": "#333333",
    "accent": "#a371f7"
  },

  "typography": {
    "font_heading": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "font_body": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "text_base": "15px",
    "leading_body": "1.5",
    "leading_heading": "1.2"
  },

  "layout": {
    "max_width": "1100px",
    "section_gap": "40px",
    "container_padding": "32px 24px"
  },

  "components": {
    "radius_sm": "3px",
    "radius_base": "6px",
    "radius_lg": "12px",
    "radius_pill": "999px",
    "shadow_card": "none",
    "shadow_hover": "none",
    "transition_base": "0.2s ease"
  }
}
